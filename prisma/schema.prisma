// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

model Monster {
  id          String   @id @default(uuid())
  name        String
  description String
  imageUrl    String
  attribute    Attribute  @default(NORMAL)
  rarity     Rarity  @default(STAR_1)
  isAiGenerated Boolean @default(false)
  aiPrompt      String?


  embedding     Unsupported("vector(1536)")?
  userId      String   


  likes       Like[]
  comments    Comment[]
  collectedBy Collection[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Like {
  id        String   @id @default(uuid()) // 複合IDが難しい場合用に追加
  userId    String   // リレーションなし
  monsterId String
  
  // user User ... 👈 削除
  monster   Monster  @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, monsterId]) // 同じ人が2回いいねできないようにする
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String   // リレーションなし
  monsterId String

  // user User ... 👈 削除
  monster   Monster  @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model Collection {
  id        String   @id @default(uuid())
  userId    String   // リレーションなし
  monsterId String
  
  // user User ... 👈 削除
  monster   Monster  @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, monsterId])
}

enum Attribute {
  FIRE
  WATER
  GRASS
  ELECTRIC
  NORMAL
}

enum Rarity {
  STAR_1
  STAR_2
  STAR_3
  STAR_4
  STAR_5
}